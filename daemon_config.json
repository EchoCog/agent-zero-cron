{
  "scheduler": {
    "enabled": true,
    "tick_interval": 60,
    "max_concurrent_tasks": 5
  },
  "workflow": {
    "enabled": true,
    "inngest_enabled": false
  },
  "agent": {
    "model_provider": "openai",
    "model_name": "gpt-4",
    "max_context_length": 8000
  },
  "daemon": {
    "auto_restart": true,
    "health_check_interval": 300,
    "max_memory_mb": 2048
  },
  "logging": {
    "level": "INFO",
    "max_files": 10,
    "max_size_mb": 100
  }
}