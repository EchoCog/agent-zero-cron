# Agent Zero Guix Deployment Environment Variables
# Copy this file to .env and modify as needed

# Git branch to deploy
BRANCH=main

# Port configuration
PORT=80
SSH_PORT=2222
SEARX_PORT=8080

# Guix environment
GUIX_PROFILE=/root/.config/guix/current
LANG=en_US.UTF-8

